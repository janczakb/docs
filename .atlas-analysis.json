  "keyFeatures": [
    "Short link generation with custom slugs and Base62 auto-keys",
    "Custom domain branding with real-time DNS verification",
    "Full analytics dashboard: visits, devices, browsers, referrers, geo",
    "Live activity feed with efficient polling",
    "SVG QR code designer with gradient, dot-style, and logo customization",
    "QR scan tracking separate from regular web clicks",
    "Advanced targeting rules: device, country, language, A/B split testing",
    "Retargeting pixels: Meta, Google Tag, LinkedIn, TikTok, Pinterest",
    "Mobile deep linking into 24+ native apps",
    "Universal Links (iOS) and Android App Links support",
    "REST API with scoped keys (read-only / read-write) and per-key rate limits",
    "HMAC-SHA256 signed webhooks on visited, created, expired, limit_reached events",
    "Server-side GA4 Measurement Protocol integration",
    "Link expiration, max visit caps, single-use mode, and password protection",
    "Offline GDPR-safe Geo-IP via MaxMind or CDN headers",
    "VPN, proxy, and bot filtering for clean analytics",
    "Folders and tags for link organization",
    "Fluent PHP builder API for programmatic link creation"
  ],
  "publicApiSurface": [
    "GET /api/short-url/links",
    "POST /api/short-url/links",
    "GET /api/short-url/links/{idOrKey}",
    "GET /api/short-url/links/{idOrKey}/stats",
    "PUT|PATCH /api/short-url/links/{idOrKey}",
    "DELETE /api/short-url/links/{idOrKey}",
    "GET /{prefix}/{key} (redirect route)",
    "GET /.well-known/apple-app-site-association",
    "GET /.well-known/assetlinks.json",
    "ShortUrl::destination(url)->urlKey()->expiresAt()->create()",
    "ShortUrl::isActive(): bool",
    "ShortUrl::isExpired(): bool",
    "ShortUrl::getShortUrl(): string",
    "ShortUrl::incrementVisits(bool): void",
    "ShortUrl::getCachedStats(): array",
    "ShortUrl::resolveDestinationUrl(Request): string",
    "ShortUrlService::create(array): ShortUrl",
    "FilamentShortUrlPlugin::make()->navigationGroup()->navigationLabel()->navigationIcon()->navigationSort()->authorizeSettingsUsing()",
    "ShortUrlVisited event",
    "short-url:aggregate-and-prune (Artisan command)",
    "short-url:sync-counters (Artisan command)"
  ]
